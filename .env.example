# DataMug Environment Variables
# Copy this file to .env.local and update values

# Ollama endpoint — local dev or Cloudflare Tunnel URL
# Local: http://localhost:11434/v1
# Production: https://ollama.datamug.com/v1
LLM_ENDPOINT=http://localhost:11434/v1

# OpenAI API key (dummy — Ollama doesn't validate this)
OPENAI_API_KEY=ollama

# Default vision model
DEFAULT_MODEL=llava:7b

# Max image size in bytes (optional, default 10MB)
MAX_IMAGE_SIZE=10000000
